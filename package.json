{
  "name": "lopho-commerce",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.11 <23"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @lopho/medusa --filter @lopho/strapi --filter @lopho/storefront dev",
    "dev:medusa": "pnpm --filter @lopho/medusa dev",
    "dev:strapi": "pnpm --filter @lopho/strapi dev",
    "dev:storefront": "pnpm --filter @lopho/storefront dev",
    "build": "pnpm --filter @lopho/medusa build && pnpm --filter @lopho/strapi build && pnpm --filter @lopho/storefront build",
    "build:medusa": "pnpm --filter @lopho/medusa build",
    "seed": "pnpm --filter @lopho/medusa seed && pnpm --filter @lopho/strapi seed",
    "seed:medusa": "pnpm --filter @lopho/medusa seed",
    "purge": "pnpm --filter @lopho/strapi purge",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.6.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/react-router": "^1.168.19",
      "@tanstack/router-core": "^1.168.19",
      "@tanstack/router-plugin": "^1.168.19",
      "@tanstack/react-store": "^0.11.0"
    },
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@medusajs/telemetry",
      "@swc/core",
      "bcrypt",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "msw",
      "msgpackr-extract",
      "protobufjs",
      "sharp"
    ]
  }
}
