{
  "name": "hakeems-commerce",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.11 <23"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @hakeems/vendure --filter @hakeems/strapi --filter @hakeems/storefront dev",
    "dev:vendure": "pnpm --filter @hakeems/vendure dev",
    "dev:worker": "pnpm --filter @hakeems/vendure worker",
    "dev:medusa": "pnpm --filter @hakeems/medusa dev",
    "dev:strapi": "pnpm --filter @hakeems/strapi dev",
    "dev:storefront": "pnpm --filter @hakeems/storefront dev",
    "build": "pnpm --filter @hakeems/vendure build && pnpm --filter @hakeems/strapi build && pnpm --filter @hakeems/storefront build",
    "build:medusa": "pnpm --filter @hakeems/medusa build",
    "seed": "pnpm --filter @hakeems/vendure seed && pnpm --filter @hakeems/strapi seed",
    "seed:medusa": "pnpm --filter @hakeems/medusa seed",
    "seed:production": "pnpm --filter @hakeems/vendure exec tsx ../../scripts/seed-production.ts",
    "purge": "pnpm --filter @hakeems/strapi purge && pnpm --filter @hakeems/vendure purge",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.6.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/react-router": "^1.168.19",
      "@tanstack/router-core": "^1.168.19",
      "@tanstack/router-plugin": "^1.168.19",
      "@tanstack/react-store": "^0.11.0"
    },
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@medusajs/telemetry",
      "@swc/core",
      "bcrypt",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "msw",
      "msgpackr-extract",
      "protobufjs",
      "sharp"
    ]
  }
}
