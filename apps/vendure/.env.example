APP_ENV=dev
PORT=3000
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin
COOKIE_SECRET=replace-with-long-cookie-secret

DB_HOST=localhost
DB_PORT=5432
DB_NAME=hakeems_vendure
DB_USERNAME=hakeems
DB_PASSWORD=hakeems
DB_SCHEMA=public

STOREFRONT_URL=http://localhost:3001
STRAPI_SYNC_URL=http://localhost:1337/api/collection-pages/sync
HAKEEMS_SYNC_SECRET=replace-with-shared-secret

# Hong Kong channel's "hongkong-stripe" PaymentMethod. Get the secret key from
# https://dashboard.stripe.com/test/apikeys, then re-run `pnpm seed` (in apps/vendure)
# so it's synced onto the payment method. For the webhook secret, run
# `pnpm stripe:listen` (requires the Stripe CLI: brew install stripe/stripe-cli/stripe)
# and paste the `whsec_...` it prints — leave that command running while testing
# payments locally, since it's what forwards Stripe's webhook to your machine.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
