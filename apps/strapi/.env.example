# Server
HOST=0.0.0.0
PORT=1337

# Secrets
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
ENCRYPTION_KEY=tobemodified

# Database
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=hakeems-strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_FILENAME=

# Vendure <-> Strapi content sync (apps/vendure/src/plugins/strapi-sync, apps/strapi/src/utils/vendure-sync.ts)
# Must match HAKEEMS_SYNC_SECRET in apps/vendure/.env exactly.
VENDURE_SYNC_URL=http://localhost:3000/webhooks/strapi
HAKEEMS_SYNC_SECRET=replace-with-shared-secret
