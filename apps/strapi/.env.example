# Server
HOST=0.0.0.0
PORT=1337

# Secrets
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
ENCRYPTION_KEY=tobemodified

# Database
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=lopho-strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_FILENAME=

# Medusa -> Strapi collection sync (apps/medusa/src/subscribers/collection-sync.ts, apps/strapi/src/api/collection-page).
# One-way only. Must match LOPHO_SYNC_SECRET in apps/medusa/.env exactly.
LOPHO_SYNC_SECRET=replace-with-shared-secret
