{
  "collectionName": "components_shared_ctas",
  "info": {
    "displayName": "CTA",
    "icon": "cursor",
    "description": "A standardized call-to-action: label, href, visual variant, and target. The single, reusable way to model any button/link across pages and blocks."
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true,
      "maxLength": 60
    },
    "href": {
      "type": "string",
      "required": true,
      "regex": "^(/[^\\s]*|https?://[^\\s]+)$"
    },
    "variant": {
      "type": "enumeration",
      "enum": ["primary", "secondary", "link"],
      "default": "primary",
      "required": true
    },
    "openInNewTab": {
      "type": "boolean",
      "default": false
    }
  }
}
