{
  "kind": "collectionType",
  "collectionName": "home_pages",
  "info": {
    "singularName": "home-page",
    "pluralName": "home-pages",
    "displayName": "Home Page",
    "description": "One entry per storefront channel (Nepal, Hong Kong): marquee, hero slider, shop-by-collection tiles, brand story, values."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "channel": {
      "type": "enumeration",
      "enum": ["nepal", "hongkong"],
      "required": true
    },
    "announcements": {
      "type": "component",
      "repeatable": true,
      "component": "layout.announcement"
    },
    "heroSlides": {
      "type": "component",
      "repeatable": true,
      "component": "layout.hero-slide"
    },
    "collectionTiles": {
      "type": "component",
      "repeatable": true,
      "component": "layout.collection-tile"
    },
    "storyEyebrow": {
      "type": "string"
    },
    "storyHeading": {
      "type": "string"
    },
    "storyParagraphs": {
      "type": "component",
      "repeatable": true,
      "component": "shared.paragraph"
    },
    "storyImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "values": {
      "type": "component",
      "repeatable": true,
      "component": "layout.value-item"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
