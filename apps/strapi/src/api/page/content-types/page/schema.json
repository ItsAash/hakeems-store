{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "A composable page built from a dynamic zone of section blocks. One entry per (slug, channel) — e.g. slug 'home' for nepal and hongkong. Marketing reorders/adds/removes sections here without code changes."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "string",
      "required": true,
      "maxLength": 120,
      "regex": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "channel": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "nepal",
        "hongkong"
      ]
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "section.hero-slider",
        "section.category-grid",
        "section.product-rail",
        "section.editorial-banner",
        "section.brand-story",
        "section.value-props",
        "section.testimonials",
        "section.faq",
        "section.prose"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "announcementBarEnabled": {
      "type": "boolean",
      "default": true
    },
    "announcements": {
      "type": "component",
      "repeatable": true,
      "component": "layout.announcement"
    }
  }
}
