{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Setting",
    "description": "Global, channel-agnostic site configuration: name, default SEO, social links, support contacts, footer/legal links."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "Hakeems"
    },
    "tagline": {
      "type": "string"
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "supportEmail": {
      "type": "email"
    },
    "supportPhone": {
      "type": "string"
    },
    "footerNote": {
      "type": "text"
    },
    "legalLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    }
  }
}
