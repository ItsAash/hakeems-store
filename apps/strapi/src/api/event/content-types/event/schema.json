{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "bannerImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "eventDate": {
      "type": "datetime",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "channel": {
      "type": "enumeration",
      "enum": ["nepal", "hongkong", "both"],
      "required": true,
      "default": "both"
    },
    "status": {
      "type": "enumeration",
      "enum": ["upcoming", "live", "ended"],
      "required": true,
      "default": "upcoming"
    },
    "featuredProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-reference.product-reference",
      "inversedBy": "events"
    }
  }
}
