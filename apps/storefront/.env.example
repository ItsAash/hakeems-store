# Vendure Shop API (public, read + cart/auth mutations — never the admin API)
VENDURE_SHOP_API_URL=http://localhost:3000/shop-api

# Strapi Content API (read-only API token, NOT the admin JWT)
STRAPI_API_URL=http://localhost:1337
STRAPI_API_TOKEN=replace-with-a-read-only-api-token

# Public asset host override for next/image remotePatterns in production
NEXT_PUBLIC_VENDURE_ASSET_HOST=

# Stripe (Hong Kong channel checkout only) — publishable key, safe for the client.
# Must match the secret key configured on the "hongkong-stripe" PaymentMethod in
# apps/vendure/.env (STRIPE_SECRET_KEY). Without a real key here, the Hong Kong
# payment step will render but fail when creating a PaymentIntent.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
