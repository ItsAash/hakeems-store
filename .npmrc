auto-install-peers=true
# Strapi's admin plugins (e.g. @strapi/plugin-users-permissions) import
# "@strapi/admin/strapi-admin" as a bare specifier assuming a flat node_modules —
# under pnpm's strict isolation, a plugin buried in the pnpm store can't see a
# sibling @strapi/* package unless it's hoisted to the root, even when the
# consuming app (apps/strapi) declares it directly. Hoisting the whole @strapi/*
# scope is Strapi's own documented fix for pnpm monorepos.
public-hoist-pattern[]=@strapi/*
