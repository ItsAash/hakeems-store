# Supabase connection — copy to a GITIGNORED .env and fill with your own values.
# NEVER commit real keys/passwords. All DB access must read from these env vars.
#
# Public-safe (client) values:
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# Server-only secrets (keep out of the browser and out of git):
SUPABASE_SECRET_KEY=sb_secret_xxx

# Direct connection is IPv6-only; use the IPv4 connection pooler for most environments.
# Session pooler (port 5432) — full SQL / migrations:
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
